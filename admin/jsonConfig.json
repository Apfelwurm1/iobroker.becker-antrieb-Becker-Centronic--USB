{
  "i18n": true,
  "type": "tabs",
  "items": {
    "tabMain": {
      "type": "panel",
      "label": "Settings",
      "items": {
        "headerSerial": {
          "type": "header",
          "size": 4,
          "text": "Serial Port Settings"
        },
        "manualMode": {
          "type": "checkbox",
          "label": "Manual Path Entry (e.g. for offline adapter or initial installation)",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "default": true
        },
        "serialPort": {
          "type": "selectSendTo",
          "label": "Detected Serial Ports",
          "command": "getSerialPorts",
          "hidden": "data.manualMode === true",
          "xs": 12,
          "sm": 8,
          "md": 6,
          "lg": 4,
          "xl": 3
        },
        "serialPortManual": {
          "type": "text",
          "label": "Manual Serial Port Path (e.g. COM3 or /dev/ttyUSB0)",
          "hidden": "data.manualMode !== true",
          "xs": 12,
          "sm": 8,
          "md": 6,
          "lg": 4,
          "xl": 3,
          "default": ""
        },
        "infoSerial": {
          "type": "staticText",
          "text": "Specify the connection path to your Becker Centronic USB Stick.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontStyle": "italic",
            "color": "gray"
          }
        }
      }
    },
    "tabUnits": {
      "type": "panel",
      "label": "Units",
      "items": {
        "headerUnits": {
          "type": "header",
          "size": 4,
          "text": "Virtual Becker Remotes (Units)"
        },
        "infoUnits": {
          "type": "staticText",
          "text": "Each row in the table represents a virtual remote control. Only one unique Unit Code (5 hex characters) must be used per remote control. This code is required to pair the virtual remote with the roller shutter motor.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontStyle": "italic",
            "color": "gray",
            "marginBottom": "15px"
          }
        },
        "generateCodeButton": {
          "type": "sendTo",
          "label": "Generate Random Unit Code",
          "command": "generateRandomCode",
          "useNative": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 2
        },
        "generatedCode": {
          "type": "text",
          "label": "Random Unit Code (Copy from here)",
          "readOnly": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 2,
          "default": ""
        },
        "units": {
          "type": "table",
          "label": "Paired Units & Remotes",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "items": [
            {
              "type": "text",
              "attr": "name",
              "title": "Remote Name",
              "width": "200px"
            },
            {
              "type": "text",
              "attr": "id",
              "title": "Unit Code (5 hex chars, e.g. 1737b)",
              "width": "180px"
            },
            {
              "type": "number",
              "attr": "increment",
              "title": "Rolling Code Counter (starts at 0)",
              "width": "150px",
              "default": 0
            }
          ]
        }
      }
    }
  }
}
