{
  "i18n": true,
  "type": "tabs",
  "items": {
    "tabMain": {
      "type": "panel",
      "label": "Settings",
      "items": {
        "headerSerial": {
          "type": "header",
          "size": 4,
          "text": "Serial Port Settings"
        },
        "serialPort": {
          "type": "select",
          "label": "Serial Port Path",
          "options": [
            { "value": "/dev/ttyUSB0", "label": "/dev/ttyUSB0 (Standard USB Serial)" },
            { "value": "/dev/ttyUSB1", "label": "/dev/ttyUSB1" },
            { "value": "/dev/ttyAMA0", "label": "/dev/ttyAMA0 (RPi Serial)" },
            { "value": "COM1", "label": "COM1" },
            { "value": "COM2", "label": "COM2" },
            { "value": "COM3", "label": "COM3" },
            { "value": "COM4", "label": "COM4" },
            { "value": "manual", "label": "Manuelle Eingabe / Custom Path" }
          ],
          "xs": 12,
          "sm": 8,
          "md": 6,
          "lg": 4,
          "xl": 3,
          "default": "manual"
        },
        "serialPortManual": {
          "type": "text",
          "label": "Manual Serial Port Path (e.g. COM3 or /dev/ttyUSB0)",
          "hidden": "data.serialPort !== 'manual'",
          "xs": 12,
          "sm": 8,
          "md": 6,
          "lg": 4,
          "xl": 3,
          "default": ""
        },
        "infoSerial": {
          "type": "staticText",
          "text": "Specify the connection path to your Becker Centronic USB Stick.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontStyle": "italic",
            "color": "gray"
          }
        }
      }
    },
    "tabUnits": {
      "type": "panel",
      "label": "Units",
      "items": {
        "headerUnits": {
          "type": "header",
          "size": 4,
          "text": "Virtual Becker Remotes (Units)"
        },
        "units": {
          "type": "table",
          "label": "Paired Units & Remotes",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "items": [
            {
              "type": "text",
              "attr": "name",
              "title": "Remote Name",
              "width": "200px"
            },
            {
              "type": "text",
              "attr": "id",
              "title": "Unit Code (5 hex chars, e.g. 1737b)",
              "width": "180px"
            },
            {
              "type": "number",
              "attr": "increment",
              "title": "Rolling Code Counter (starts at 0)",
              "width": "150px",
              "default": 0
            }
          ]
        }
      }
    }
  }
}